{
  "name": "lodop-bridge-desktop",
  "version": "1.0.0",
  "description": "LODOP Node 核心库 + Tauri 客户端",
  "main": "src/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run -w frontend dev",
    "build": "npm run -w frontend build",
    "build:mac": "tauri build --target universal-apple-darwin --bundles dmg --no-sign",
    "build:win": "tauri build --bundles nsis --no-sign",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "rm -rf dist",
    "lint": "echo \"no lint configured\"",
    "test": "echo \"no tests configured\""
  },
  "keywords": [
    "lodop",
    "print",
    "proxy",
    "tauri"
  ],
  "author": "",
  "license": "MIT",
  "workspaces": [
    "frontend"
  ],
  "files": [
    "dist",
    "config",
    "src/**/*",
    "public/**/*",
    "demo/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ip": "^1.1.8",
    "ipaddr.js": "^2.1.0",
    "winston": "^3.13.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}

{
  "name": "lodop-nodejs",
  "version": "1.0.0",
  "description": "LODOP Node 核心库 + macOS Electron 客户端",
  "main": "main/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build:renderer && electron . --dev",
    "dev:lib": "tsc --watch",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "webpack --config webpack.config.js",
    "build:icon": "scripts/build-icon.sh",
    "build:mac": "npm run build:renderer && npm run build:icon && (hdiutil detach \"/Volumes/C-Lodop Client 1.0.0\" 2>/dev/null || true) && PYTHON_PATH=$(command -v python3 2>/dev/null || echo /usr/bin/python3) electron-builder --mac",
    "clean": "rm -rf dist",
    "lint": "echo \"no lint configured\"",
    "test": "echo \"no tests configured\"",
    "postinstall": "electron-builder install-app-deps && npx playwright install chromium || true"
  },
  "keywords": [
    "lodop",
    "print",
    "proxy",
    "macos",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "config",
    "main/**/*",
    "renderer/**/*",
    "public/**/*",
    "demo/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "config": "^3.3.9",
    "ipaddr.js": "^2.1.0",
    "winston": "^3.13.0",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "playwright": "^1.40.0",
    "electron-store": "^8.1.0",
    "ip": "^1.1.8",
    "os": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.6.0",
    "@electron/rebuild": "^4.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3"
  },
  "build": {
    "appId": "com.lodop.macos.client",
    "productName": "C-Lodop Client",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "public/**/*",
      "demo/**/*",
      "package.json"
    ]
  }
}
